APP_NAME="AI-Driven Energy Supply Chain Resilience"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG="false"
DEMO_MODE="true"
SECRET_KEY="replace-this-with-a-long-random-secret"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"
ALGORITHM="HS256"

DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/energy_resilience"
REDIS_URL="redis://localhost:6379/0"

BACKEND_CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500"
LOG_LEVEL="INFO"
DOCS_URL="/docs"
REDOC_URL="/redoc"
OPENAPI_URL="/openapi.json"

# =========================
# LLM / SUMMARIZATION
# =========================
LLM_PROVIDER="gemini"
LLM_MODEL="gpt-4o-mini"
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
GEMINI_MODEL="gemini-1.5-flash"
GROQ_API_KEY="your-groq-api-key-here"
GROQ_BASE_URL="https://api.groq.com/openai/v1"

# =========================
# GEOPOLITICAL / NEWS
# =========================
GDELT_ENABLED="true"
GDELT_BASE_URL="https://api.gdeltproject.org/api/v2"
NEWSAPI_ENABLED="false"
NEWSAPI_API_KEY=""
NEWSAPI_BASE_URL="https://newsapi.org/v2"
EVENT_REGISTRY_ENABLED="false"
EVENT_REGISTRY_API_KEY=""

# =========================
# SANCTIONS
# =========================
OFAC_ENABLED="true"
OFAC_BASE_URL="https://sanctionssearch.ofac.treas.gov"
UK_SANCTIONS_ENABLED="false"
EU_SANCTIONS_ENABLED="false"
UN_SANCTIONS_ENABLED="false"

# =========================
# AIS / SHIPPING
# =========================
AIS_PROVIDER="mock"
MARINETRAFFIC_API_KEY=""
MARINETRAFFIC_BASE_URL="https://services.marinetraffic.com/api"
VESSELFINDER_API_KEY="your-vesselfinder-api-key-here"
VESSELFINDER_BASE_URL="https://api.vesselfinder.com"
DATALASTIC_API_KEY=""
DATALASTIC_BASE_URL="https://api.datalastic.com/api/v0"

# =========================
# PRICES
# =========================
PRICE_PROVIDER="mock"
ALPHAVANTAGE_API_KEY="your-alphavantage-api-key-here"
ALPHAVANTAGE_BASE_URL="https://www.alphavantage.co/query"
EIA_API_KEY="your-eia-api-key-here"
EIA_BASE_URL="https://api.eia.gov/v2"
CRUDEPRICE_API_KEY="your-crudeprice-api-key-here"
CRUDEPRICE_BASE_URL="https://www.crudepriceapi.com/api"
